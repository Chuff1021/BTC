CAE_ENV=development
CAE_DATABASE_PATH=data/alpha.duckdb
CAE_PARQUET_ROOT=data/parquet
CAE_ARTIFACT_ROOT=artifacts
CAE_LOG_LEVEL=INFO
CAE_ALLOW_NETWORK=true
CAE_PAPER_TRADING_ONLY=true
CAE_STARTING_CASH=100000
CAE_FEE_BPS=6
CAE_SLIPPAGE_BPS=4
# Injected automatically when the existing Neon resource is connected in Vercel.
POSTGRES_URL=
DATABASE_URL=
CRON_SECRET=
# Optional public-data provider keys. Never commit real values.
FRED_API_KEY=
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
