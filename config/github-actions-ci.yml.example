name: CI
on:
  push:
  pull_request:
permissions:
  contents: read
jobs:
  test:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ["3.12", "3.13"]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python-version }}
          cache: pip
      - run: python -m pip install -e ".[dev]"
      - run: ruff check src tests
      - run: mypy src
      - run: pytest --cov=alpha_engine --cov-report=term-missing --cov-fail-under=75
      - name: Reject committed secrets
        run: |
          ! git grep -En '(sk_live_|BEGIN (RSA|OPENSSH) PRIVATE KEY|api[_-]?key\s*=\s*[^[:space:]]+)' -- ':!*.example' ':!*.md'
